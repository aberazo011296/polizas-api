APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOADS_DIR=./uploads
DATA_DIR=./data
TEMPLATES_DIR=./templates
# Tesseract path (override if not in PATH)
# TESSERACT_CMD=/usr/bin/tesseract

# Persistencia (ver docs/adr/0001-persistencia-mongodb.md)
# "local": plantillas.json + templates/*.docx en disco (default, sin Mongo).
# "mongo": colección `plantillas` + GridFS para .docx + colección `auditoria`.
STORAGE_BACKEND=local
# Solo si STORAGE_BACKEND=mongo. Con docker-compose (servicio "mongo"):
#   docker compose up -d mongo
# y luego, para correr la API local con venv (fuera del compose), usar
# localhost en vez del nombre de servicio "mongo":
MONGO_URI=mongodb://polizas:polizas_dev_pw@localhost:27017
MONGO_DB_NAME=polizas
# Credenciales del contenedor mongo de docker-compose (no usar en producción).
MONGO_INITDB_ROOT_USERNAME=polizas
MONGO_INITDB_ROOT_PASSWORD=polizas_dev_pw

# Seguridad
# Token que el host (WebView) envía como `Authorization: Bearer <token>`.
# Vacío en dev = API sin autenticación. EN PRODUCCIÓN definir un valor fuerte.
# API_TOKEN=
# Orígenes permitidos para CORS (coma-separados). En producción, el del host.
CORS_ORIGINS=http://localhost:5173,http://localhost:5199
# Tamaños máximos de subida en bytes (default 10 MB cada uno)
# MAX_PDF_SIZE_BYTES=10485760
# MAX_DOCX_SIZE_BYTES=10485760
#
# NOTA: el rate limiting (anti-fuerza-bruta / ráfagas) se hace en el proxy /
# API gateway del host, no en la app. Ej. nginx:
#   limit_req_zone $binary_remote_addr zone=api:10m rate=60r/m;
#   client_max_body_size 10m;   # tope de body a nivel de proxy
